{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "timezone": "Asia/Kolkata",

  "extends": [
    "config:recommended",
    ":semanticCommits",
    ":dependencyDashboard",
    ":disableRateLimiting",
    ":preserveSemverRanges",
    "helpers:pinGitHubActionDigests",
    ":configMigration",
    "abandonments:recommended",
    "workarounds:all",
    "group:monorepos",
    "group:nodeJs",
    "group:githubArtifactActions",
    "group:react",
    "group:vitestMonorepo",
    "group:linters",
    "group:definitelyTyped"
  ],

  "assignees": ["teneplaysofficial"],
  "addLabels": ["dependencies", "renovate"],

  "gitIgnoredAuthors": ["66853113+pre-commit-ci[bot]@users.noreply.github.com"],

  "ignoreAuthors": ["pre-commit-ci[bot]"],

  "osvVulnerabilityAlerts": true,

  "vulnerabilityAlerts": {
    "labels": ["security"],
    "automerge": false
  },

  "minimumReleaseAge": "3 days",
  "rebaseWhen": "auto",

  "prHourlyLimit": 5,
  "prConcurrentLimit": 10,

  "automerge": true,
  "automergeStrategy": "squash",

  "dependencyDashboardAutoclose": false,

  "lockFileMaintenance": {
    "enabled": false,
    "schedule": ["on sunday"],
    "groupName": "lockfile maintenance",
    "automerge": true
  },

  "postUpdateOptions": ["pnpmDedupe"],

  "packageRules": [
    {
      "description": "Never automerge major updates",
      "matchUpdateTypes": ["major"],
      "automerge": false,
      "addLabels": ["breaking-change", "major"]
    },
    {
      "description": "Automerge patch updates",
      "matchUpdateTypes": ["patch"],
      "automerge": true,
      "addLabels": ["patch"]
    },
    {
      "description": "Automerge minor devDependency updates",
      "matchDepTypes": ["devDependencies"],
      "matchUpdateTypes": ["minor"],
      "automerge": true,
      "addLabels": ["minor"]
    },
    {
      "description": "Group Astro ecosystem",
      "matchPackagePatterns": [
    "^astro",
    "^@astrojs/"
  ],
  "groupName": "astro",
  "addLabels": ["astro"]
    },
    {
      "description": "Group ESLint packages",
      "matchPackagePatterns": [
        "^eslint",
        "^@eslint/",
        "^typescript-eslint",
        "^@typescript-eslint/"
      ],
      "groupName": "eslint",
      "addLabels": ["eslint"]
    },
    {
      "description": "Group Prettier packages",
      "matchPackagePatterns": [
        "^prettier",
        "^@prettier/"
      ],
      "groupName": "prettier",
      "addLabels": ["prettier"]
    },
    {
      "description": "Group GitHub Actions non-major updates",
      "matchManagers": ["github-actions"],
      "matchUpdateTypes": ["minor", "patch"],
      "groupName": "github actions",
      "automerge": true,
      "addLabels": ["github-actions"]
    },
    {
      "description": "Group Docker non-major updates",
      "matchManagers": ["dockerfile", "docker-compose"],
      "matchUpdateTypes": ["minor", "patch"],
      "groupName": "docker",
      "addLabels": ["docker"]
    },
    {
  "description": "Group Vite ecosystem",
  "matchPackagePatterns": [
    "^vite",
    "^@vitejs/"
  ],
  "groupName": "vite",
  "addLabels": ["vite"]
    },
    {
      "description": "Security vulnerability fixes",
      "matchCategories": ["security"],
      "minimumReleaseAge": "0 days",
      "automerge": true,
      "addLabels": ["security"]
    }
  ]
}
