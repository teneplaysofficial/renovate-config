{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "timezone": "Asia/Kolkata",

  "extends": [
    "config:recommended",
    ":semanticCommits",
    ":dependencyDashboard",
    ":disableRateLimiting",
    ":preserveSemverRanges",
    "helpers:pinGitHubActionDigests",
    ":configMigration",
    "abandonments:recommended",
    "workarounds:all",
    "group:definitelyTyped",
    "group:monorepos",
    "group:nodeJs",
    "group:githubArtifactActions",
    "group:react",
    "group:pnpm",
    "group:vite",
    "group:eslintMonorepo",
    "group:typescript-eslintMonorepo",
    "group:storybookMonorepo",
    "group:astroMonorepo",
    "group:vitestMonorepo",
    "group:linters"
  ],

  "assignees": ["teneplaysofficial"],
  "addLabels": ["dependencies", "renovate"],

  "gitIgnoredAuthors": ["66853113+pre-commit-ci[bot]@users.noreply.github.com"],

  "ignoreAuthors": ["pre-commit-ci[bot]"],

  "osvVulnerabilityAlerts": true,

  "vulnerabilityAlerts": {
    "labels": ["security"],
    "automerge": false
  },

  "minimumReleaseAge": "3 days",
  "rebaseWhen": "auto",

  "prHourlyLimit": 5,
  "prConcurrentLimit": 10,

  "automerge": true,
  "automergeStrategy": "squash",

  "dependencyDashboardAutoclose": false,

  "lockFileMaintenance": {
    "enabled": false,
    "schedule": ["on sunday"],
    "groupName": "lockfile maintenance",
    "automerge": true
  },

  "postUpdateOptions": ["pnpmDedupe"],

  "packageRules": [
    {
      "description": "Never automerge major updates",
      "matchUpdateTypes": ["major"],
      "automerge": false,
      "addLabels": ["breaking-change", "major"]
    },
    {
      "description": "Automerge patch updates",
      "matchUpdateTypes": ["patch"],
      "automerge": true,
      "addLabels": ["patch"]
    },
    {
      "description": "Automerge minor devDependency updates",
      "matchDepTypes": ["devDependencies"],
      "matchUpdateTypes": ["minor"],
      "automerge": true,
      "addLabels": ["minor"]
    },
    {
      "description": "Group Prettier packages",
      "matchPackagePatterns": [
        "^prettier",
        "^@prettier/"
      ],
      "groupName": "prettier",
      "addLabels": ["prettier"]
    },
    {
  "description": "Never automerge major GitHub Actions updates",
  "matchManagers": ["github-actions"],
  "matchUpdateTypes": ["major"],
  "automerge": false,
  "addLabels": ["breaking-change", "major"]
},
{
  "description": "Automerge minor and patch GitHub Actions updates",
  "matchManagers": ["github-actions"],
  "matchUpdateTypes": ["minor", "patch"],
  "groupName": "github actions",
  "automerge": true,
  "addLabels": ["github-actions"]
},
    {
      "description": "Group Docker non-major updates",
      "matchManagers": ["dockerfile", "docker-compose"],
      "matchUpdateTypes": ["minor", "patch"],
      "groupName": "docker",
      "addLabels": ["docker"]
    },{
    "description": "Automerge security/vulnerability fixes, but ONLY non-major",
    "matchUpdateTypes": ["patch", "minor"],
    "isVulnerabilityAlert": true,
    "automerge": true, "minimumReleaseAge": "0 days",

    "addLabels": ["security"]
  },
  {
    "description": "Never automerge major security updates - needs manual review",
    "matchUpdateTypes": ["major"],
    "isVulnerabilityAlert": true,
    "automerge": false,
    "addLabels": ["security", "breaking-change", "major"]
  }
  ]
}
